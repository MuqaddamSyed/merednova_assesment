# Copy to .env and fill in ONE provider (Aider reads these automatically).
# This avoids the OpenRouter browser sign-up redirect.

# --- Option 1: OpenAI (recommended for simplicity) ---
OPENAI_API_KEY=sk-your-key-here
# Then in config.yaml set agent args to include:
#   --model gpt-4o

# --- Option 2: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# agent args: --model sonnet

# --- Option 3: OpenRouter (API key — no browser OAuth) ---
# Get a key at https://openrouter.ai/keys (not the sign-up OAuth flow)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# agent args: --model openrouter/anthropic/claude-3.5-sonnet
